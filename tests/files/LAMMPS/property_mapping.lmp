units	     metal
atom_style   atomic
dimension    3

lattice	     bcc 1.0
region	     box block 0 2 0 2 0 2
create_box   1 box
create_atoms 1 box


mass         1 1
neighbor     0.8 bin

dump	     1 all custom 1 property_mapping.dump id type x y z vx vy vz
dump_modify  1 colname 1 ParticleIdentifier
dump_modify  1 colname 2 ParticleType
dump_modify  1 colname 3 Position.X
dump_modify  1 colname 4 Position.Y
dump_modify  1 colname 5 Position.Z
dump_modify  1 colname 6 Velocity.X
dump_modify  1 colname 7 Velocity.Y
dump_modify  1 colname 8 Velocity.Z

run	         0
